{
	"name": "animal-kingdom",
	"version": "0.0.0",
	"description": "Animal Kingdom battle game",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"build": "tsc && vite build",
		"lint": "eslint . --fix",
		"format": "npx biome format --write . && prettier --write .",
		"ci:eslint": "eslint . --format json --output-file eslint_report.json",
		"ci:prettier": "prettier --check \"src/**/*.{js,ts,css,md,json}\"",
		"ci:biome": "npx biome format .",
		"ci:typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@chromatic-com/storybook": "^5.0.2",
		"@eslint/js": "^10.0.1",
		"@storybook/addon-a11y": "^10.3.1",
		"@storybook/addon-docs": "^10.3.1",
		"@storybook/addon-onboarding": "^10.3.1",
		"@storybook/addon-vitest": "^10.3.1",
		"@storybook/react-vite": "^10.3.1",
		"@testing-library/react": "^16.3.2",
		"@sentry/vite-plugin": "^5.1.1",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.38.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-storybook": "^10.3.1",
		"globals": "^17.4.0",
		"jiti": "^2.5.0",
		"jsdom": "^29.0.1",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"storybook": "^10.3.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vitest": "^4.0.12",
		"vitest-browser-react": "^2.1.0"
	},
	"dependencies": {
		"lucide-react": "^0.577.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	}
}
